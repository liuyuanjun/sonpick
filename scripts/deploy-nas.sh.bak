#!/usr/bin/env bash
# 打包 + rsync 到 NAS + docker compose up
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=lib.sh
source "$ROOT/scripts/lib.sh"
cd "$ROOT"

SSH_HOST="${SONPICK_SSH_HOST:-qnap}"
REMOTE_DIR="${SONPICK_REMOTE_DIR:-/home/admin/Docker/sonpick}"
PACK_ONLY=0
RSYNC_ONLY=0
NO_BUILD=0
FORCE_BUILD=0
SKIP_FRONTEND=0

usage() {
  cat <<EOF
Usage: $0 [options]

  --pack-only       只生成 deploy/，不 rsync
  --rsync-only      跳过打包构建，直接同步已有 deploy/
  --no-build        远端只 up/restart，不 docker compose build
  --force-build     强制 pnpm build 前端
  --skip-frontend   打包时不构建前端（要求 web/dist 已存在）
  --host HOST       SSH Host（默认 qnap）
  --remote DIR      远端目录（默认 /home/admin/Docker/sonpick）
  -h, --help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pack-only) PACK_ONLY=1; shift ;;
    --rsync-only) RSYNC_ONLY=1; shift ;;
    --no-build) NO_BUILD=1; shift ;;
    --force-build) FORCE_BUILD=1; shift ;;
    --skip-frontend) SKIP_FRONTEND=1; shift ;;
    --host) SSH_HOST="$2"; shift 2 ;;
    --remote) REMOTE_DIR="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown arg: $1" ;;
  esac
done

if [[ "$RSYNC_ONLY" -eq 0 ]]; then
  prep_args=()
  [[ "$FORCE_BUILD" -eq 1 ]] && prep_args+=(--force-build)
  [[ "$SKIP_FRONTEND" -eq 1 ]] && prep_args+=(--skip-build)
  if [[ ${#prep_args[@]} -gt 0 ]]; then
    "$ROOT/scripts/prepare-deploy.sh" "${prep_args[@]}"
  else
    "$ROOT/scripts/prepare-deploy.sh"
  fi
fi

[[ -f deploy/web/dist/index.html ]] || die "deploy/web/dist missing; run without --rsync-only first"
[[ -f deploy/Dockerfile ]] || die "deploy/Dockerfile missing"
[[ -f deploy/docker-compose.yml ]] || die "deploy/docker-compose.yml missing"

if [[ "$PACK_ONLY" -eq 1 ]]; then
  log "pack-only done → deploy/"
  exit 0
fi

log "ssh check: $SSH_HOST"
ssh -o BatchMode=yes -o ControlMaster=no -o ConnectTimeout=12 "$SSH_HOST" "mkdir -p '$REMOTE_DIR/data' '$REMOTE_DIR/downloads' '$REMOTE_DIR/logs'"

log "rsync → ${SSH_HOST}:${REMOTE_DIR}/"
rsync -az --delete --human-readable \
  -e "ssh -o BatchMode=yes -o ControlMaster=no" \
  --exclude 'data/' \
  --exclude 'downloads/' \
  --exclude 'logs/' \
  --exclude '.env' \
  --exclude '__pycache__/' \
  --exclude '*.pyc' \
  deploy/ "${SSH_HOST}:${REMOTE_DIR}/"

log "ensure remote .env (never overwrite existing)"
ssh -o BatchMode=yes -o ControlMaster=no "$SSH_HOST" "cd '$REMOTE_DIR' && mkdir -p data downloads logs && if [ ! -f .env ]; then if [ -f .env.example ]; then cp .env.example .env; echo '[sonpick] created .env from example'; else printf 'SECRET_KEY=change-me\nADMIN_PASSWORD=admin\n' > .env; echo '[sonpick] created default .env'; fi; fi"

# stop old container from other project dir if name conflicts
ssh -o BatchMode=yes -o ControlMaster=no "$SSH_HOST" "docker ps -a --format '{{.Names}}' | grep -qx sonpick && docker inspect -f '{{.Config.Labels}}' sonpick 2>/dev/null | head -c 200 || true" >/dev/null || true

if [[ "$NO_BUILD" -eq 1 ]]; then
  log "remote: docker compose up -d (no rebuild)"
  ssh -o BatchMode=yes -o ControlMaster=no "$SSH_HOST" "cd '$REMOTE_DIR' && docker compose up -d && docker compose ps && curl -sS http://127.0.0.1:8301/health || true"
else
  log "remote: docker compose up -d --build"
  ssh -o BatchMode=yes -o ControlMaster=no "$SSH_HOST" "cd '$REMOTE_DIR' && docker compose up -d --build && docker compose ps && sleep 3 && (curl -sS http://127.0.0.1:8301/health || (echo '--- logs ---'; docker compose logs --tail=100; exit 1))"
fi

log "done"
